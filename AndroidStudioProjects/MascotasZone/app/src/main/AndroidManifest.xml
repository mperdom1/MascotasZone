<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MascotasZone">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
        </activity>
        <activity
            android:name=".AddPetActivity"
            android:exported="false"
            android:label="Agregar Mascota" />
        <activity
            android:name=".CreateCommunityActivity"
            android:exported="false"
            android:label="Crear Comunidad" />
        <activity
            android:name=".CreateServiceRequestActivity"
            android:exported="false"
            android:label="Nueva Solicitud" />
        <activity
            android:name=".CommunityDetailActivity"
            android:exported="false"
            android:label="Detalle de Comunidad" />
        <activity
            android:name=".ContactListActivity"
            android:exported="true"
            android:label="Mis Contactos" />
        <activity
            android:name=".AddContactActivity"
            android:exported="false"
            android:label="Nuevo Contacto" />
    </application>

</manifest>